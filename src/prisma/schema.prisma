generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"] // <--- AÑADE ESTO
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  PENDING
}

model Property {
  id            String         @id @default(uuid())
  title         String
  titleEn       String?
  description   String         @db.Text
  descriptionEn String?        @db.Text
  price         Decimal        @db.Decimal(12, 2)
  country       String         @default("Venezuela")
  city          String
  zone          String
  bedrooms      Int            @default(0)
  bathrooms     Decimal        @db.Decimal(3, 1)
  parkingSpaces Int            @default(0)
  squareMeters  Int
  status        PropertyStatus @default(AVAILABLE)
  type          String
  operationType String         // Campo añadido para resolver el error de persistencia
  images        String[]
  amenities     String[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  isPrivate     Boolean        @default(false)
  isActive      Boolean        @default(true)

  appointments  Appointment[]
  favorites     Favorite[]

  @@index([status])
  @@index([type])
}

model Appointment {
  id            String   @id @default(uuid())
  propertyId    String?
  clientId      String?
  clientName    String   @default("Sin nombre")
  clientEmail   String
  clientPhone   String   @default("0000000000")
  preferredDate DateTime
  notes         String?  @db.Text
  calendlyUri   String?
  status        String   @default("scheduled")
  createdAt     DateTime @default(now())

  property      Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  profile       Profile?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([clientId])
}

model Favorite {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
}

model Profile {
  id           String        @id
  email        String        @unique
  role         String        @default("cliente")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]

  @@map("profiles")
}